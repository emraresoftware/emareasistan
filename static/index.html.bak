    <div class="scenario-tabs">
      <button class="scenario-tab active" onclick="showScenario('karsilama')">👋 Müşteri Karşılama</button>
      <button class="scenario-tab" onclick="showScenario('siparis')">🛒 Sipariş Alma</button>
      <button class="scenario-tab" onclick="showScenario('kargo')">📦 Kargo Takibi</button>
