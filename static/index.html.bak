<script>
// Navbar scroll effect
window.addEventListener('scroll', () => {
  document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 10);
});

// Scenario tabs
function showScenario(id) {
  document.querySelectorAll('.scenario-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.scenario-tab').forEach(t => t.classList.remove('active'));
  document.getElementById('sc-' + id).classList.add('active');
  event.currentTarget.classList.add('active');
}

// Demo chat
const demoReplies = [
  "Ürün görsellerini hemen paylaşıyorum. Elit Serisi çok şık duruyor Passat'ta! 📸",
  "Montaj işlemleri mağazamızda yapılıyor. Süre yaklaşık 2-2.5 saat. Randevu almak ister misiniz?",
  "Kargo ile tüm Türkiye'ye gönderim yapıyoruz. Teslimat 1-3 iş günü.",
  "Havale, kredi kartı ve kapıda ödeme seçeneklerimiz mevcut.",
  "Siparişiniz için ad soyad, telefon ve adres bilgilerinizi paylaşır mısınız?",
  "Teşekkürler! Size daha fazla yardımcı olabilmem için başka sorunuz var mı? 😊"
];
let demoIdx = 0;

function sendDemo() {
  const input = document.getElementById('demoInput');
  const text = input.value.trim();
  if (!text) return;
  const msgs = document.getElementById('demoMessages');
  const userMsg = document.createElement('div');
  userMsg.className = 'demo-msg user';
  userMsg.textContent = text;
  msgs.appendChild(userMsg);
  input.value = '';
  setTimeout(() => {
    const botMsg = document.createElement('div');
    botMsg.className = 'demo-msg bot';
    botMsg.textContent = demoReplies[demoIdx % demoReplies.length];
    msgs.appendChild(botMsg);
    demoIdx++;
    msgs.scrollTop = msgs.scrollHeight;
  }, 800);
}
</script>

</body>
