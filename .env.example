# AI API - OpenAI veya Gemini (biri yeterli)
OPENAI_API_KEY=sk-xxx   # TTS (sesli yanıt) ve Whisper STT için; sesli mesajla gelen müşteriye sesli yanıt
GEMINI_API_KEY=   # https://aistudio.google.com/apikey adresinden alın
GEMINI_MODEL=gemini-2.5-flash-lite   # veya gemini-2.0-flash (kotada sorun varsa değiştirin)
LOCAL_LLM_ENABLED=false
LOCAL_LLM_BASE_MODEL=Qwen/Qwen2.5-0.5B-Instruct
LOCAL_LLM_ADAPTER_PATH=./scripts/local_llm/artifacts/local_lora
LOCAL_LLM_CHAT_SCRIPT=./scripts/local_llm/chat.py
LOCAL_LLM_PYTHON_BIN=./scripts/local_llm/.venv/bin/python
LOCAL_LLM_MAX_NEW_TOKENS=64
LOCAL_LLM_TIMEOUT_SEC=18
LOCAL_LLM_MIN_CONFIDENCE=55

# Meridyen Oto Web Sitesi
BASE_URL=https://meridyenoto.com
# Konum (müşteri istediğinde paylaşılır)
MERIDYEN_ADDRESS=Maltepe Mah. Eski Çırpıcı Yolu Sok. Merter Meridyen İş Merkezi No:1 G-20, Zeytinburnu/İstanbul
MERIDYEN_PHONE=0532 294 38 11
MERIDYEN_LAT=41.0056
MERIDYEN_LNG=28.8842

# Kargo API Entegrasyonları
# Yurtiçi Kargo
YURTICI_API_KEY=
# Aras Kargo
ARAS_API_KEY=
# MNG Kargo
MNG_API_KEY=

# WhatsApp Business API (Meta Cloud API)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
ASISTAN_API_TIMEOUT_MS=120000

# Telegram Bot
TELEGRAM_BOT_TOKEN=

# Instagram Messaging API (Meta - Facebook Page + Instagram Business hesabı gerekli)
INSTAGRAM_PAGE_ID=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_VERIFY_TOKEN=meridyen_verify

# Database
# SQLite (varsayılan):
DATABASE_URL=sqlite+aiosqlite:///./asistan.db
# PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/asistan

# Super admin (e-posta + şifre ile giriş - production'da mutlaka değiştirin)
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=your-secure-password

# E-posta (kayıt onayı için)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com
APP_BASE_URL=http://localhost:8000
# Production: https://asistan.example.com

# WhatsApp Bridge (QR tarama sayfası - production'da subdomain)
WHATSAPP_BRIDGE_URL=http://localhost:3100
# Production: https://qr.asistan.example.com

# Chat denetim (asenkron AI ile sohbet kalite kontrolü - analitik)
CHAT_AUDIT_ENABLED=false
CHAT_AUDIT_SAMPLE_RATE=20

# Opsiyonel: Redis (boşsa in-memory cache)
# REDIS_URL=redis://localhost:6379/0

# Opsiyonel: Tenant API şifreleme (min 32 karakter)
# ENCRYPTION_KEY=your-secret-key-min-32-chars

# Opsiyonel: Cron/planlı işler güvenliği
# CRON_SECRET_KEY=random-secret

# Opsiyonel: Session (production'da mutlaka değiştirin)
# SESSION_SECRET_KEY=emare-asistan-session-change-in-production

# Opsiyonel: SMS bildirimleri (Netgsm vb.)
# NETGSM_USERCODE=
# NETGSM_PASSWORD=
# NETGSM_MSGHEADER=EMARE
